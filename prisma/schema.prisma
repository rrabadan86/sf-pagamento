generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model GestorUser {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  senha    String
  nome     String
  criadoEm DateTime @default(now())
}

model ProfessorPercentual {
  id             Int      @id @default(autoincrement())
  idProfessorEvo String
  nomeProfessor  String
  percentual     Float    @default(20)
  piso           Float    @default(55)
  teto           Float    @default(90)
  dataInicio     DateTime @default(now())
  criadoEm       DateTime @default(now())

  @@index([idProfessorEvo, dataInicio])
}

model RelatorioStatus {
  id             Int      @id @default(autoincrement())
  idProfessorEvo String
  nomeProfessor  String
  mes            Int
  ano            Int
  status         String   @default("Gerado")
  versao         Int      @default(1)
  geradoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  observacao     String?

  @@unique([idProfessorEvo, mes, ano])
}

model AcademiaConfig {
  id           Int      @id @default(autoincrement())
  nomeAcademia String   @default("Academia")
  logoBase64   String?
  atualizadoEm DateTime @updatedAt
}

model Aluno {
  idEvo        String     @id
  nome         String
  email        String?
  celular      String?
  contratos    Contrato[]
  checkins     Checkin[]
  criadoEm     DateTime   @default(now())
  atualizadoEm DateTime   @updatedAt
}

model Contrato {
  idEvo        String   @id
  idAluno      String
  nomePlano    String
  status       String // Ativo, Cancelado, Trancado, etc.
  dataInicio   DateTime
  dataFim      DateTime
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno Aluno @relation(fields: [idAluno], references: [idEvo], onDelete: Cascade)

  @@index([idAluno])
}

model Aula {
  idEvo          String    @id
  idProfessorEvo String
  horarioInicio  DateTime
  horarioFim     DateTime
  atividade      String?
  nomeProfessor  String?
  checkins       Checkin[]
}

model Checkin {
  idEvo    String   @id
  idAluno  String
  idAula   String?
  dataHora DateTime
  status   String // Presente, Faltou, etc.

  aluno Aluno @relation(fields: [idAluno], references: [idEvo], onDelete: Cascade)
  aula  Aula? @relation(fields: [idAula], references: [idEvo], onDelete: SetNull)

  @@index([idAluno, dataHora])
  @@index([idAula])
}
